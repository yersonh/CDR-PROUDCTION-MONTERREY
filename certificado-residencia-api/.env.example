APP_NAME="Certificado de Residencia Digital"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# BASE DE DATOS
# Desarrollo local: SQLite (sin instalación). Deja DB_CONNECTION=sqlite.
# Producción: MySQL. Cambia DB_CONNECTION=mysql y completa las credenciales.
# ---------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=certificado_residencia
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------------------
# FRONTEND SPA (React) — Sanctum / CORS
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DOMAIN=localhost

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# CORREO — notificaciones al ciudadano (radicación, certificado emitido)
# Dev: 'log' (los correos se escriben en storage/logs/laravel.log).
# Producción (Railway): 'brevo' (API HTTP transaccional, NO SMTP) + BREVO_API_KEY.
# ---------------------------------------------------------------------------
MAIL_MAILER=log
# MAIL_MAILER=brevo
BREVO_API_KEY=
MAIL_FROM_ADDRESS="no-reply@monterrey-casanare.gov.co"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# ALMACENAMIENTO DE DOCUMENTOS
# Dev: se guarda en storage/app/private (dejar vacío).
# Producción (Railway): apunta al volumen persistente montado, p. ej. /data.
# ---------------------------------------------------------------------------
LOCAL_STORAGE_PATH=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# INTEGRACIONES EXTERNAS — Core institucional (lectura) y VUR (envío/recepción)
# ---------------------------------------------------------------------------
CORE_API_URL=
CORE_API_TOKEN=

VUR_API_URL=
# Mismo valor que el token Sanctum "vur-integration" (usuario "Servicio VUR")
# que VUR ya usa para autenticarse contra /recibidos-vur — es un secreto
# compartido bidireccional, no un token nuevo.
VUR_API_TOKEN=

# ---------------------------------------------------------------------------
# IA — Gemini (Google) valida el certificado electoral adjunto antes de que
# Secretaría prevalide (ver ValidarCertificadoElectoralConIA). Sin esta key
# el job falla y reintenta; la solicitud queda disponible para validación
# manual desde ElectoralForm mientras tanto, no bloquea nada.
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

VITE_APP_NAME="${APP_NAME}"
